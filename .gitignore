# =============================================================================
# NexusStream — Git Ignore Rules
# =============================================================================

# ---------------------------------------------------------------------------
# Environment / Secrets (CRITICAL)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.pub
*.crt
*.p12
*.pfx
*.secret
secrets/
jwt_keys/

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
bower_components/
jspm_packages/
.npm/

# ---------------------------------------------------------------------------
# Python (Analytics & Dashboard Services)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.tox/

# ---------------------------------------------------------------------------
# Build & Distribution
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
.docusaurus/
.cache/
*.tsbuildinfo
frontend/dist/
frontend/build/

# ---------------------------------------------------------------------------
# Database & Persistence (Local data only)
# ---------------------------------------------------------------------------
influxdb-data/
postgres-data/
redis-data/
rabbitmq-data/
*.db
*.sqlite
*.sql
!**/init.sql
!**/migrations/*.sql

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# IDEs & OS Specific
# ---------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini
.history/
