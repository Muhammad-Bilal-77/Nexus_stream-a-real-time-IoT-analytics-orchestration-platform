# =============================================================================
# NexusStream — Environment Example
# =============================================================================
# Copy this file to .env and fill in all secret values before running.
# NEVER commit .env to version control.

COMPOSE_PROJECT_NAME=nexusstream
NODE_ENV=production

# Ports
INGESTION_PORT=3001
AUTH_PORT=3002
ANALYTICS_PORT=8001
DASHBOARD_PORT=8002
POSTGRES_PORT=5432
REDIS_PORT=6379
INFLUXDB_PORT=8086
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_DB=nexusstream
POSTGRES_USER=nexus_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# InfluxDB
INFLUXDB_HOST=influxdb
INFLUXDB_ORG=nexusstream-org
INFLUXDB_BUCKET=iot_metrics
INFLUXDB_TOKEN=CHANGE_ME_INFLUX_TOKEN
INFLUXDB_ADMIN_USER=influx_admin
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME_INFLUX_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_IOT_CHANNEL=iot:metrics

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=nexus_rabbit
RABBITMQ_PASSWORD=CHANGE_ME_RABBIT_PASSWORD
RABBITMQ_VHOST=nexusstream

# Ingestion Service
DEVICE_COUNT=10
PUBLISH_INTERVAL_MS=100
ANOMALY_RATE=0.05
BUFFER_MAX_SIZE=1000
RETRY_INTERVAL_MS=3000

# Auth Service
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
